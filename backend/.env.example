# LLM provider
# Set LLM_PROVIDER=gemini (recommended) or groq
LLM_PROVIDER=gemini

# Gemini (recommended)
GEMINI_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini/gemini-2.5-flash-lite

# Groq (optional fallback)
# GROQ_API_KEY=gsk_your_groq_key_here
# LLM_MODEL=groq/llama-3.1-8b-instant

# Gmail SMTP
GMAIL_USER=ryansokolowsky@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Public backend URL (update when ngrok URL changes)
PUBLIC_BACKEND_URL=https://your-ngrok-url.ngrok.io

# Optional branded email assets
EMAIL_ASSET_BASE_URL=https://rsokolowskydev.github.io/mark-miller-agent/images
EMAIL_HERO_IMAGE_URL=https://rsokolowskydev.github.io/mark-miller-agent/images/Untitled.png
EMAIL_BADGE_IMAGE_URL=https://rsokolowskydev.github.io/mark-miller-agent/images/1.png
EMAIL_HERO_IMAGE_PATH=../images/Untitled.png
EMAIL_BADGE_IMAGE_PATH=../images/1.png
EMAIL_CTA_URL=https://www.markmillersubarusouthtowne.com/inventory/new/Subaru
