# LLM provider
# Set LLM_PROVIDER=gemini (recommended) or groq
LLM_PROVIDER=gemini

# Gemini (recommended)
GEMINI_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini/gemini-1.5-flash

# Groq (optional fallback)
# GROQ_API_KEY=gsk_your_groq_key_here
# LLM_MODEL=groq/llama-3.1-8b-instant

# Gmail SMTP
GMAIL_USER=ryansokolowsky@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Demo recipient
DEMO_EMAIL=ryansokolowsky@gmail.com

# Public backend URL (update when ngrok URL changes)
PUBLIC_BACKEND_URL=https://your-ngrok-url.ngrok.io
